# Binance API 代理（如需翻墙访问，填写代理地址）
# 格式示例:
#   BINANCE_PROXY=127.0.0.1:7890
#   BINANCE_PROXY=127.0.0.1:7890:user:pass
BINANCE_PROXY=

# 覆盖 API 地址（可选，默认 https://api.binance.com）
# BINANCE_API_BASE=https://api.binance.com

# 回测最低置信度 % （默认 40）
# BACKTEST_MIN_CONF=40

# --watch 刷新间隔秒数（默认 60）
# SIGNAL_INTERVAL=60
